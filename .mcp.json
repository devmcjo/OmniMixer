{
  "mcpServers": {
    "serena": {
      "command": "npx",
      "args": ["-y", "serena-slim"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "shrimp-task-manager": {
      "command": "node",
      "args": [
        "${PROJECT_DIR_SHRIMP_TASK_MANAGER}/dist/index.js"
      ],
      "env": {
        "DATA_DIR": "${PROJECT_DIR}/.claude/shrimp_data",
        "TEMPLATES_USE": "en",
        "ENABLE_GUI": "false"
      }
    }
  }
}
