<Window x:Class="OmniMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OmniMixer.ViewModels"
        mc:Ignorable="d"
        Title="OmniMixer — Multi-Output Audio Router"
        Height="600" Width="1000"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Boolean을 반전하는 컨버터 -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- 채널 스트립 컨테이너 스타일 -->
        <Style x:Key="ChannelStripBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#2d2d2d" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <!-- 레벨 미터 ProgressBar 스타일 (임시) -->
        <Style x:Key="LevelMeterStyle" TargetType="ProgressBar">
            <Setter Property="Orientation" Value="Vertical" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="#1a1a1a" />
            <Setter Property="Foreground" Value="#4CAF50" />
            <Setter Property="BorderBrush" Value="#333333" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- 볼륨 슬라이더 스타일 (세로, Inverted) -->
        <Style x:Key="VolumeSliderStyle" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical" />
            <Setter Property="Minimum" Value="-80" />
            <Setter Property="Maximum" Value="6" />
            <Setter Property="Value" Value="0" />
            <Setter Property="IsDirectionReversed" Value="True" />
            <Setter Property="TickFrequency" Value="6" />
            <Setter Property="TickPlacement" Value="BottomRight" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="150" />
        </Style>

        <!-- 팬 슬라이더 스타일 (가로) -->
        <Style x:Key="PanSliderStyle" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Minimum" Value="-1" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Value" Value="0" />
            <Setter Property="TickFrequency" Value="0.5" />
            <Setter Property="TickPlacement" Value="BottomRight" />
        </Style>

        <!-- Mute 버튼 스타일 -->
        <Style x:Key="MuteButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Content" Value="MUTE" />
            <Setter Property="Background" Value="#444444" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#d32f2f" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />      <!-- 헤더: 입력 장치 선택 -->
            <RowDefinition Height="*" />          <!-- 채널 스트립 -->
            <RowDefinition Height="Auto" />      <!-- 상태 표시줄 -->
            <RowDefinition Height="Auto" />      <!-- 하단 컨트롤: Start/Stop -->
        </Grid.RowDefinitions>

        <!-- === 헤더: 입력 장치 선택 === -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="10" BorderBrush="#444444" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Input Device:"
                          Foreground="White"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                <ComboBox Width="300"
                          ItemsSource="{Binding InputDevices}"
                          SelectedItem="{Binding SelectedInputDevice}"
                          DisplayMemberPath="FriendlyName"
                          IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                          VerticalContentAlignment="Center"/>

                <Button Content="🔄"
                        Command="{Binding RefreshDevicesCommand}"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                        Margin="10,0,0,0"
                        Width="30"/>

                <TextBlock Text="OmniMixer"
                          Foreground="#4CAF50"
                          FontSize="18"
                          FontWeight="Bold"
                          HorizontalAlignment="Right"
                          Margin="30,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- === 채널 스트립 영역 === -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Channels}" Margin="5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ChannelStripBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />   <!-- 채널 번호 -->
                                    <RowDefinition Height="Auto" />   <!-- 출력 장치 선택 -->
                                    <RowDefinition Height="Auto" />   <!-- 팬 슬라이더 -->
                                    <RowDefinition Height="*" />       <!-- 볼륨/미터 -->
                                    <RowDefinition Height="Auto" />   <!-- Mute 버튼 -->
                                </Grid.RowDefinitions>

                                <!-- 채널 번호 -->
                                <TextBlock Grid.Row="0"
                                          Text="{Binding ChannelIndex, StringFormat='CH {0}'}"
                                          Foreground="White"
                                          FontWeight="Bold"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,5"/>

                                <!-- 출력 장치 선택 -->
                                <ComboBox Grid.Row="1"
                                          ItemsSource="{Binding DataContext.OutputDevices, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          SelectedValue="{Binding SelectedDeviceId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="FriendlyName"
                                          IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource InverseBooleanConverter}}"
                                          Margin="0,0,0,10"
                                          VerticalContentAlignment="Center">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDeviceId}" Value="{x:Null}">
                                                    <Setter Property="ToolTip" Value="출력 장치를 선택하세요" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                </ComboBox>

                                <!-- 팬 슬라이더 -->
                                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                                    <Slider Style="{StaticResource PanSliderStyle}"
                                            Value="{Binding Pan}" />
                                    <Grid>
                                        <TextBlock Text="L" Foreground="#888" HorizontalAlignment="Left" />
                                        <TextBlock Text="C" Foreground="#888" HorizontalAlignment="Center" />
                                        <TextBlock Text="R" Foreground="#888" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>

                                <!-- 볼륨/미터 영역 -->
                                <Grid Grid.Row="3" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 좌측 미터 -->
                                    <ProgressBar Grid.Column="1"
                                                  Style="{StaticResource LevelMeterStyle}"
                                                  Value="{Binding MeterLevelLeft}" />

                                    <!-- 볼륨 슬라이더 -->
                                    <Slider Grid.Column="2"
                                             Style="{StaticResource VolumeSliderStyle}"
                                             Value="{Binding VolumeDb}"
                                             Margin="8,0" />

                                    <!-- 우측 미터 -->
                                    <ProgressBar Grid.Column="3"
                                                  Style="{StaticResource LevelMeterStyle}"
                                                  Value="{Binding MeterLevelRight}" />
                                </Grid>

                                <!-- Mute 버튼 -->
                                <ToggleButton Grid.Row="4"
                                              Style="{StaticResource MuteButtonStyle}"
                                              IsChecked="{Binding IsMuted}"
                                              HorizontalAlignment="Center"
                                              Margin="0,5,0,0" />

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- === 상태 표시줄 === -->
        <Border Grid.Row="2" Background="#2d2d2d" Padding="10,5" BorderBrush="#444444" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                      Foreground="#aaa"
                      FontSize="12" />
        </Border>

        <!-- === 하단 컨트롤: Start/Stop === -->
        <Border Grid.Row="3" Background="#2d2d2d" Padding="15" BorderBrush="#444444" BorderThickness="0,1,0,0">
            <Button Command="{Binding StartStopCommand}"
                    Content="{Binding StartStopButtonText}"
                    Width="150" Height="40"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="{Binding IsRunning, Converter={StaticResource BooleanToStartStopBrushConverter}}"
                    Foreground="White" />
        </Border>

    </Grid>
</Window>
