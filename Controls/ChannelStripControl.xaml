<UserControl x:Class="OmniMixer.Controls.ChannelStripControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:OmniMixer.ViewModels"
             xmlns:conv="clr-namespace:OmniMixer.Converters"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="90">

    <UserControl.Resources>
        <!-- 컬러 팔레트: Apple Dark Mode 스타일 -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="ChannelBackgroundBrush" Color="#2C2C2E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3C"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E8E93"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#0A84FF"/>
        <SolidColorBrush x:Key="MeterBackgroundBrush" Color="#1A1A1C"/>

        <!-- 채널 번호 스타일 -->
        <Style x:Key="ChannelNumberStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,8,0,6"/>
        </Style>

        <!-- 장치 선택 ComboBox 스타일 (Apple 스타일) -->
        <Style x:Key="DeviceComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Background" Value="#3A3A3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#48484A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Pan 슬라이더 스타일 (Apple 스타일) -->
        <Style x:Key="PanSliderStyle" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Minimum" Value="-1"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Value" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4"
                                    Background="{StaticResource BorderBrush}"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Ellipse Fill="{StaticResource TextPrimaryBrush}"
                                                         Stroke="{StaticResource AccentBlueBrush}"
                                                         StrokeThickness="0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 볼륨 슬라이더 스타일 (프로페셔널 페이더) -->
        <Style x:Key="VolumeFaderStyle" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="IsDirectionReversed" Value="True"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- 트랙 배경 -->
                            <Border Width="4"
                                    Background="{StaticResource BorderBrush}"
                                    CornerRadius="2"
                                    HorizontalAlignment="Center"/>

                            <!-- 활성 영역 (0dB 표시) -->
                            <Border Width="4"
                                    Height="2"
                                    Background="#636366"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,-60,0,0"/>

                            <!-- Unity Gain 표시 (-12dB ≈ 50%) -->
                            <Border Width="6"
                                    Height="1"
                                    Background="{StaticResource TextSecondaryBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,-20,0,0"
                                    Opacity="0.5"/>

                            <Track x:Name="PART_Track" Orientation="Vertical">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Background="Transparent"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="28" Height="18">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="#48484A"
                                                        BorderBrush="{StaticResource AccentBlueBrush}"
                                                        BorderThickness="2"
                                                        CornerRadius="4">
                                                    <Grid>
                                                        <!-- 페이더 핸 중앙선 -->
                                                        <Rectangle Width="12" Height="2"
                                                                   Fill="{StaticResource TextPrimaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 레벨 미터 ProgressBar 스타일 -->
        <Style x:Key="LevelMeterStyle" TargetType="ProgressBar">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="{StaticResource MeterBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Width="{TemplateBinding Width}">
                            <Grid>
                                <!-- dB 눈금선 (10개) -->
                                <UniformGrid Rows="10" HorizontalAlignment="Stretch">
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,1" Opacity="0.3"/>
                                    <Border BorderBrush="#3A3A3C" BorderThickness="0,0,0,0" Opacity="0.3"/>
                                </UniformGrid>

                                <!-- 0dB 표시선 -->
                                <Border Height="1"
                                        Background="#636366"
                                        VerticalAlignment="Center"
                                        Margin="0,-60,0,0"/>

                                <!-- 레벨 바 -->
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="1"
                                        VerticalAlignment="Bottom"
                                        Height="{TemplateBinding Value, Converter={StaticResource LevelToHeightConverter}}"
                                        MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mute 버튼 스타일 (Apple 스타일 토글) -->
        <Style x:Key="MuteButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="6,8,6,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF453A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 레벨 → 높이 컨버터 -->
        <conv:LevelToHeightConverter x:Key="LevelToHeightConverter"/>
    </UserControl.Resources>

    <!-- 메인 채널 스트립 레이아웃 -->
    <Border Background="{StaticResource ChannelBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Margin="2,4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>      <!-- 채널 번호 -->
                <RowDefinition Height="Auto"/>      <!-- 출력 장치 -->
                <RowDefinition Height="Auto"/>      <!-- Pan -->
                <RowDefinition Height="*"/>         <!-- 볼륨/미터 -->
                <RowDefinition Height="Auto"/>      <!-- Mute -->
            </Grid.RowDefinitions>

            <!-- 채널 번호 -->
            <TextBlock Grid.Row="0"
                       Text="{Binding ChannelIndex, StringFormat='CH {0}'}"
                       Style="{StaticResource ChannelNumberStyle}"/>

            <!-- 출력 장치 선택 -->
            <ComboBox Grid.Row="1"
                      Style="{StaticResource DeviceComboBoxStyle}"
                      ItemsSource="{Binding OutputDevices}"
                      SelectedValue="{Binding SelectedDeviceId}"
                      SelectedValuePath="Id"
                      DisplayMemberPath="FriendlyName"
                      IsEnabled="{Binding DataContext.IsRunning,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Converter={StaticResource InverseBooleanConverter}}">
                <ComboBox.ToolTip>
                    <TextBlock Text="출력 오디오 장치 선택" Foreground="Black"/>
                </ComboBox.ToolTip>
            </ComboBox>

            <!-- Pan 섹션 -->
            <StackPanel Grid.Row="2" Margin="0,6,0,4">
                <TextBlock Text="PAN"
                           Style="{StaticResource ChannelNumberStyle}"
                           FontSize="9"
                           Margin="0,0,0,2"/>
                <Slider x:Name="PanSlider"
                        Style="{StaticResource PanSliderStyle}"
                        Value="{Binding Pan}"/>
                <Grid Margin="8,2,8,0">
                    <TextBlock Text="L"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="C"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="R"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9"
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>

            <!-- 볼륨/미터 섹션 -->
            <Grid Grid.Row="3" Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>   <!-- 좌측 미터 -->
                    <ColumnDefinition Width="Auto"/>   <!-- 볼륨 페이더 -->
                    <ColumnDefinition Width="Auto"/>   <!-- 우측 미터 -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측 레벨 미터 -->
                <ProgressBar Grid.Column="1"
                             Style="{StaticResource LevelMeterStyle}"
                             Value="{Binding MeterLevelLeft}"
                             Foreground="{Binding MeterLevelLeft,
                                          Converter={StaticResource LevelToColorConverter}}"
                             Height="280"/>

                <!-- 볼륨 페이더 -->
                <Slider x:Name="VolumeSlider"
                        Grid.Column="2"
                        Style="{StaticResource VolumeFaderStyle}"
                        Value="{Binding VolumeDb,
                                Converter={StaticResource DbToSliderPositionConverter}}"
                        Height="280"/>

                <!-- 우측 레벨 미터 -->
                <ProgressBar Grid.Column="3"
                             Style="{StaticResource LevelMeterStyle}"
                             Value="{Binding MeterLevelRight}"
                             Foreground="{Binding MeterLevelRight,
                                          Converter={StaticResource LevelToColorConverter}}"
                             Height="280"/>
            </Grid>

            <!-- dB 값 표시 -->
            <TextBlock Grid.Row="3"
                       Text="{Binding VolumeDb, Converter={StaticResource LevelToDbTextConverter}}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="9"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,4"/>

            <!-- Mute 버튼 -->
            <ToggleButton Grid.Row="4"
                          Style="{StaticResource MuteButtonStyle}"
                          IsChecked="{Binding IsMuted}"
                          Content="MUTE"/>
        </Grid>
    </Border>
</UserControl>
